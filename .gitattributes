# Define a conversão padrão para o seu código (todos os arquivos de texto)
# O Git fará checkout como CRLF no Windows e manterá LF no repositório.
* text=auto

# Regra para Forçar a Limpeza: Todos os arquivos de texto no repositório são LF.
# Esta linha garante que seu código (fora da node_modules) use a quebra de linha Linux no Git.
* text eol=lf

# Binary files — never touch line endings
*.webm binary
*.mp4 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.exe binary
*.dll binary
*.node binary
*.wasm binary

backend/node_modules/ binary